{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fredoka|Gochi Hand|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Fredoka, Gochi Hand, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tilt|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, tilt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ink|yellow|green|sky|pink|peach|purple|paper)$/]",
        "message": "<Badge> variant must be one of 'ink' | 'yellow' | 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|disabled|iconLeft|iconRight|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, disabled, iconLeft, iconRight, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|green|sky|pink|peach|purple|blue|white|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'blue' | 'white' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tint|pop|tilt|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tint, pop, tilt, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:paper|cream|lemon|green|sky|pink|peach|purple|yellow)$/]",
        "message": "<Card> tint must be one of 'paper' | 'cream' | 'lemon' | 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Character'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|seed|size|base|flip|alt|key|ref|className|style|children)$/]",
        "message": "<Character> doesn't accept that prop. Declared props: id, seed, size, base, flip, alt."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|color|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, color, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:green|sky|pink|peach|purple|yellow)$/]",
        "message": "<Checkbox> color must be one of 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|selected|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: color, selected, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:yellow|green|sky|pink|peach|purple)$/]",
        "message": "<Chip> color must be one of 'yellow' | 'green' | 'sky' | 'pink' | 'peach' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|shape|size|label|disabled|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, shape, size, label, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|white|green|sky|pink|peach|purple)$/]",
        "message": "<IconButton> variant must be one of 'primary' | 'white' | 'green' | 'sky' | 'pink' | 'peach' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:round|square)$/]",
        "message": "<IconButton> shape must be one of 'round' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|height|base|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, height, base."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:mascot|wordmark)$/]",
        "message": "<Logo> variant must be one of 'mascot' | 'wordmark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|color|label|height|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, color, label, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:yellow|green|sky|pink|peach|purple)$/]",
        "message": "<ProgressBar> color must be one of 'yellow' | 'green' | 'sky' | 'pink' | 'peach' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<RadioOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:tint|label|size|tilt|children|key|ref|className|style|children)$/]",
        "message": "<Sticker> doesn't accept that prop. Declared props: tint, label, size, tilt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:green|sky|pink|peach|purple|yellow)$/]",
        "message": "<Sticker> tint must be one of 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakTracker'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|done|today|color|labels|key|ref|className|style|children)$/]",
        "message": "<StreakTracker> doesn't accept that prop. Declared props: total, done, today, color, labels."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakTracker'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:yellow|green|sky|pink|peach|purple)$/]",
        "message": "<StreakTracker> color must be one of 'yellow' | 'green' | 'sky' | 'pink' | 'peach' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|color|label|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, color, label, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:green|sky|pink|peach|purple|yellow)$/]",
        "message": "<Switch> color must be one of 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'yellow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|rows|showCount|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, hint, rows, showCount."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tint|icon|onClose|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tint, icon, onClose, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:green|sky|pink|peach|purple|yellow|paper)$/]",
        "message": "<Toast> tint must be one of 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'yellow' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WordPrompt'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|words|tint|align|key|ref|className|style|children)$/]",
        "message": "<WordPrompt> doesn't accept that prop. Declared props: kicker, words, tint, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='WordPrompt'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:green|sky|pink|peach|purple|lemon)$/]",
        "message": "<WordPrompt> tint must be one of 'green' | 'sky' | 'pink' | 'peach' | 'purple' | 'lemon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WordPrompt'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<WordPrompt> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
